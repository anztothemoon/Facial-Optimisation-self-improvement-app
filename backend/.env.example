PORT=3001

# Use `production` in deployed environments so HSTS and stricter defaults apply.
# NODE_ENV=production

# Sentry (optional) — https://sentry.io
# SENTRY_DSN=https://...@o....ingest.sentry.io/...

# Comma-separated allowed browser/app origins (omit for local dev = allow all).
# Example: https://your-app.com,https://www.your-app.com
# CORS_ORIGIN=

# Stripe (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_...
# Dashboard → Webhooks → Signing secret (use CLI whsec only for local `stripe listen`)
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Firestore TTL for stripeWebhookEvents docs (30–365, default 90). Set TTL on field `expireAt` in Firebase Console.
# STRIPE_WEBHOOK_EVENT_TTL_DAYS=90

# Billing → Products → create 3 recurring prices (weekly / monthly / yearly)
STRIPE_PRICE_WEEKLY=price_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
# Optional: one-time or limited coupon for weekly intro offer (e.g. £3.50 first week)
STRIPE_WEEKLY_INTRO_COUPON=coupon_...

# Redirect URLs after Checkout (Stripe replaces {CHECKOUT_SESSION_ID})
# Example: https://yourdomain.com/success or app://stripe-success
STRIPE_SUCCESS_URL=http://localhost:8081/stripe-success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:8081/stripe-cancel

# Stripe Customer Portal return URL (fallback if client does not send returnUrl)
STRIPE_PORTAL_RETURN_URL=http://localhost:8081

# Firebase Admin — use ONE of:
# (A) Entire service account JSON as a single line (good for CI)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# (B) Path to the downloaded JSON file (recommended for local dev — never commit the file)
# FIREBASE_SERVICE_ACCOUNT_PATH=C:\path\to\looksmaxxing-pro-firebase-adminsdk-xxxxx.json
# (C) Standard Google env name also works:
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\key.json
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=

# AI coach — required for GPT replies (otherwise heuristic-only)
OPENAI_API_KEY=sk-...
# Optional: Azure OpenAI or proxy base (default https://api.openai.com/v1)
# OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=900

# Optional rate limits (requests per minute per IP)
# RATE_LIMIT_CHAT_PER_MIN=40
# RATE_LIMIT_ANALYSIS_PER_MIN=20

# Optional: HSTS max-age in seconds (only sent when NODE_ENV=production)
# HSTS_MAX_AGE_SECONDS=15552000

# Optional: Cross-Origin-Resource-Policy header (default cross-origin)
# CORP_POLICY=cross-origin
