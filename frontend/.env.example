# --- White-label / acquisition (optional) ---
# EXPO_PUBLIC_APP_DISPLAY_NAME=Looksmax Pro
# EXPO_PUBLIC_COMPANY_NAME=Anz To The Moon
# EXPO_PUBLIC_SUPPORT_EMAIL=
# GitHub Pages template (replace with your user/repo if different):
# EXPO_PUBLIC_PRIVACY_URL=https://anztothemoon.github.io/Facial-Optimisation-self-improvement-app/privacy.html
# EXPO_PUBLIC_TERMS_URL=https://anztothemoon.github.io/Facial-Optimisation-self-improvement-app/terms.html
# EXPO_PUBLIC_DATA_PROCESSING_URL=https://example.com/dpa
# EXPO_PUBLIC_PAYWALL_MERCHANT_NAME=Looksmax Pro

# Physical phone: use your PC LAN IP, e.g. http://192.168.1.10:3001 (not localhost)
EXPO_PUBLIC_API_URL=http://localhost:3001

# If Expo QR fails: scan inside Expo Go (not the phone camera), or run: npm run start:tunnel
# AI Coach + face analysis + Stripe API: must point at your running backend.
# Physical device: use your PC LAN IP, e.g. http://192.168.1.10:3001 (same Wi‑Fi as the phone).

# Sentry error reporting (https://sentry.io) — optional
# EXPO_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...

# Model used when user enables "Use my OpenAI key" (BYOK) on device
# EXPO_PUBLIC_OPENAI_MODEL=gpt-4o-mini

# Stripe publishable key (pk_test_... from Stripe Dashboard)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: keep Premium access while Stripe subscription is past_due (payment retry window)
# EXPO_PUBLIC_SUBSCRIPTION_INCLUDE_PAST_DUE=1

# Stripe Checkout (backend must expose /api/stripe/* — see backend/.env.example)
# After payment, Stripe redirects; webhook updates Firestore `users/{uid}.subscription`.

# Firebase (Project settings → General → Your apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In: Web client ID (OAuth 2.0 Client IDs in Google Cloud Console)
# Also create iOS/Android OAuth clients and enable Google sign-in in Firebase Auth.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
